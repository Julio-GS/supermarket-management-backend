NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@host/db?sslmode=verify-full
TEST_DATABASE_URL=postgresql://user:password@host/test_db?sslmode=verify-full
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ARCA (ex AFIP) electronic invoicing - optional, V1 only supports Factura B / Consumidor Final
ARCA_ENABLED=false
# ARCA_MOCK returns deterministic fake invoices without real cert/key or SDK calls.
# Use ARCA_ENABLED=true + ARCA_MOCK=true for local development without real credentials.
ARCA_MOCK=false
ARCA_PRODUCTION=false
ARCA_CUIT=20111111112
ARCA_PTO_VTA=1
# ARCA_CERT and ARCA_KEY must be the raw PEM contents, NOT base64-encoded.
# You can paste them as true multiline values, or as single-line quoted strings
# using \n escapes; both forms are normalized to LF before being passed to the SDK.
# Alternatively, leave these empty and set ARCA_CERT_PATH / ARCA_KEY_PATH below.
# When ARCA_MOCK=true, cert/key are not required and can be left empty/commented.
ARCA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
ARCA_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Optional: read PEM from files instead of inline env values.
# ARCA_CERT_PATH=./path/to/cert.crt
# ARCA_KEY_PATH=./path/to/key.key
# Optional: directory where the SDK stores WSAA access tickets locally.
# Defaults to a folder inside node_modules, which is not ideal for production.
# ARCA_TICKET_PATH=./tmp/arca-tickets
# Optional: enable legacy HTTPS agent for ARCA/AFIP servers in Node.js.
# Set to true if you see TLS/SSL handshake errors in production.
# ARCA_USE_HTTPS_AGENT=false
