meta {
  name: Get Product
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/products/{{productId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

vars:pre-request {
  baseUrl: http://localhost:3000/api/v1
  productId: 7a771024-7206-4938-ba3d-40d2fed335fd
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("returns the requested product", function() {
    expect(res.body.id).to.equal(bru.getVar("productId"));
  });
}
