meta {
  name: Get Product
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/products/{{productId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

vars:pre-request {
  baseUrl: http://localhost:3001/api/v1
  productId: 00fe6a18-ef9b-46c4-a7be-8df87d9255e9
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("returns the requested product", function() {
    expect(res.body.id).to.equal(bru.getVar("productId"));
  });
}
